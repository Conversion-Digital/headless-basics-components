  "scripts": {
    "lint": "eslint \"src/**/*.{ts,tsx}\" --fix --ignore-pattern \"**/*.stories.*\"",
    "build:js": "babel src --out-dir dist --extensions \".js,.jsx,.ts,.tsx\"",
    "build:types": "tsc",
    "build:css": "postcss src/theme/default/styles/globals.css -o dist/styles.css && cpy \"src/**/*.css\" dist --parents",
    "build:assets": "npx cpy \"./assets/**/*\" \"./dist/assets\"",
    "build:package": "npx cpy \"./package.json\" \"./dist\"",
    "build": "npm run build:js && npm run build:types && npm run build:css && npm run build:assets && npm run build:package && npm run postbuild",
    "storybook": "cross-env STORYBOOK_ENV=storybook storybook dev -p 6006",
    "storybook:build": "cross-env STORYBOOK_ENV=storybook storybook build",
    "tailwind:build": "pnpm tailwindcss --cwd ./ -i ./src/theme/default/styles/globals.css -o ./dist/theme/default/styles/globals.css",
    "test": "jest",
    "chromatic": "npx chromatic --project-token=chpt_219e0bf9f15c669",
    "postbuild": "find dist -name '*.js' -exec sed -i 's/\\.css\\.js/\\.css/g' {} +"
  }, 
