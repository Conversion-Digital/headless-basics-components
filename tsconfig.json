{
  "compilerOptions": {
    "outDir": "./dist/",
    "declaration": true,
    "emitDeclarationOnly": true,
    "target": "ESNext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "typeRoots": ["node_modules/@types", "src/theme/utils"]
  },
  "include": ["**/*.css", "**/*.ts", "**/*.tsx", "**/*.js", "src/theme/utils/**/*.d.ts", "node_modules/@conversiondigital/headless-basics-data/**/*"],
  "exclude": ["node_modules", "./dist/**/*", "**/*.stories.*"]
}
