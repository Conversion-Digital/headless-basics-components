STEP 6: Edit File: {COMPONENT}/components/index.tsx

    Description: Uses the variant field to render all variants.

    Example:
        ``` tsx
        import React from "react";
        import { componentBoilerPlate } from "@conversiondigital/headless-basics-data/src/component-tools/componentBoilerPlate";
        import type { ViewComponentProps } from "@conversiondigital/headless-basics-data/src/interfaces/ThemeConfig.interface";
        import DemoVariant from "./variants/demoVariant";
        import { getLogger, logPrefix } from "@conversiondigital/headless-basics-data/src";
        import {COMPONENT}DefaultVariant from "./variants/{COMPONENT}DefaultVariant";

        export const log = getLogger("default.components.heartcore.template.variants");

        export default function {COMPONENT}UI(dynamicComponent: ViewComponentProps) {
          const { variant, matchingData } = componentBoilerPlate(dynamicComponent);
          if (!matchingData) return null;
          log.trace(`${logPrefix} {COMPONENT}UI started, matchingData: ${JSON.stringify(matchingData)}`);
          switch (variant) {
            case "xDemo":
              return <DemoVariant matchingData={matchingData} {...dynamicComponent} />;
            default:
              return <{COMPONENT}DefaultVariant matchingData={matchingData} {...dynamicComponent} />;
          }
        }
STEP 7: Edit File: {COMPONENT}/components/variants/demoVariant.tsx

    Description: Renders an example variant using data from demoVariantData.ts.

    Example:  
      ``` tsx
      import React from "react"; import { StandardComponentProps } from "@conversiondigital/headless-basics-components/src/interfaces/standardComponentProps"; import { demoVariantData } from "./data/demoVariantData";

      const DemoVariant: React.FC<StandardComponentProps> = ({ blueprint, componentInformation, matchingData }) => { return ( <section> <h2>{matchingData?.title || demoVariantData.title}</h2> <p>{matchingData?.subtitle || demoVariantData.subtitle}</p> </section> ); };

      export default DemoVariant;

STEP 9: Edit File: index.ts

    Description: Index file with the component name changed. Must contain the signature:  async function getConfig(): Promise<ThemeConfig> { const config = await getThemeConfig('template'); config.view = View; // Import or define 'View' from your local "view.tsx" return config; } export default getConfig(); 

    Must handle the correct import statements for getThemeConfig and ThemeConfig.

    Example: 
      ``` ts
      import { getLogger, getThemeConfig } from "@conversiondigital/headless-basics-data/src";
      import { View } from "./view";
      import { ThemeConfig } from "@conversiondigital/headless-basics-data/src/interfaces"


      getLogger("theme.components.{COMPONENT}")

      async function getConfig(): Promise<ThemeConfig> {
          const config = await getThemeConfig('{COMPONENT}');
          config.view = View;
          return config;
      }
      export default getConfig();


STEP 10: Edit File: {COMPONENT}/sanity-schema.ts
    Description: Top-level CMS schema mapping fields from demoVariantData.ts.
    Instructions:
        - Provide an example with selectableVariant, sortOrder, or any unique fields referencing your new component's design images.
        - Make sure to have import statements from the Sanity library, for example:  import { defineField, defineType } from "sanity"; // Define your schema with fields such as: export default defineType({ name: "xComponent", title: "X Component", type: "object", fields: [ defineField({ name: "selectableVariant", title: "Selectable Variant", type: "string", options: { list: [{ title: "Default", value: "default" }, { title: "xDemo", value: "xDemo" }] } }), defineField({ name: "sortOrder", title: "Sort Order", type: "number" }), // additional fields... ] }); 
        - don't guess the icons to use, just use > use import {EyeOpenIcon} from '@sanity/icons'  (if needed)
STEP 11: Edit File: {COMPONENT}/sanity-query.ts
          
    Description: GraphQL query using fragments. Must gather fields from mobile.png/desktop.png.
    Instructions:  
        - Requires a single function only: export function getQuery(pageAndComponentCombo: PageAndSingleComponentDetails): string 

    Example:  import { PageAndSingleComponentDetails } from "@conversiondigital/headless-basics-data/src/interfaces";

    export function getQuery(pageAndComponentCombo: PageAndSingleComponentDetails): string { return /* GraphQL */ ` query AllPage($slug: String!) { allPage(where: { slug_current: { eq: $slug } }) { title ... components { ...componentFields } } }

    fragment componentFields on XComponent {
      selectableVariant
      sortOrder
      // additional fields...
    }
    `; } 

STEP 12: Edit File: {COMPONENT}/sanity-mapping.ts
    Example:
        ``` ts
        import { getLogger, logPrefix, PageAndSingleComponentDetails } from "@conversiondigital/headless-basics-data/src"
        import { extractComponentsFromSanityData } from "@conversiondigital/headless-basics-data/src/cms/sanity/sanityMappingUtils"

        export const log = getLogger("default.components.sanity.{COMPONENT}.mapping")

        export async function mapIdentifierData(pageAndComponentCombo: PageAndSingleComponentDetails) {
          log.trace(
            `${logPrefix()}[${pageAndComponentCombo.component.identifier}][${pageAndComponentCombo.page.source}][${pageAndComponentCombo.page.preliminarySlug}] mapIdentifierData started, ${JSON.stringify(pageAndComponentCombo?.component?.data)}`
          );

          const content = pageAndComponentCombo?.component?.data
          const matchingData = extractComponentsFromSanityData(content, "{COMPONENT}", log)

          if (!(matchingData?.image && matchingData.backgroundImage)) {
            matchingData.image = matchingData.backgroundImage;
          }

          return matchingData
        }




STEP 13: Edit File: {COMPONENT}/view.tsx
    Description: Dynamically load components/index.ts in a "use server" approach.
    Example: 
        ``` tsx
        'use server'

        import { ViewComponentProps } from "@conversiondigital/headless-basics-data/src";
        import dynamic from "next/dynamic"

        const {COMPONENT}UI = dynamic(() => import("./components"), { loading: () => (<p>Loading...</p>) })

        export async function View(dynamicComponent: ViewComponentProps) {
          return <{COMPONENT}UI {...dynamicComponent} />
        }

