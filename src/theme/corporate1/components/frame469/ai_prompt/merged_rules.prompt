      // Define the cl-dark variant
      addVariant('cl-dark', ({ modifySelectors, separator }) => {
        modifySelectors(({ className }) => {
          return `.cl-dark .${e(`cl-dark${separator}${className}`)}`;
        });
      });
    })
  ],
};
</file>

