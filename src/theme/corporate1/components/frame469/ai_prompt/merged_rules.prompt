          config.view = View;
          return config;
      }
      export default getConfig();


STEP 10: Edit File: {COMPONENT}/sanity-schema.ts
    Description: Top-level CMS schema mapping fields from demoVariantData.ts.
    Instructions:
        - Add fields selectableVariant, sortOrder, and any unique fields referencing your new component's design images.
        - Make sure to have import statements from the Sanity library, for example:  import { defineField, defineType } from "sanity"; // Define your schema with fields such as: export default defineType({ name: "xComponent", title: "X Component", type: "object", fields: [ defineField({ name: "selectableVariant", title: "Selectable Variant", type: "string", options: { list: [{ title: "Default", value: "default" }, { title: "xDemo", value: "xDemo" }] } }), defineField({ name: "sortOrder", title: "Sort Order", type: "number" }), // additional fields... ] }); 
        - don't guess the icons to use, just use > use import {EyeOpenIcon} from '@sanity/icons'  (if needed)
        - Replace all reference to 'Template' and define schema type as '{COMPONENT}'.
        - Use the correct type for each field, e.g., string, number, image, etc.
        - Use the correct title for each field, e.g., "Title", "Subtitle", etc.
        - Use the correct name for each field, e.g., "title", "subtitle", etc.
        - Use the correct description for each field, e.g., "The title of the component", "The subtitle of the component", etc.

STEP 11: Edit File: {COMPONENT}/sanity-query.ts
          
    Description: GraphQL query using fragments. Must gather fields from mobile.png/desktop.png.
    Instructions:  
        - Requires a single function only: export function getQuery(pageAndComponentCombo: PageAndSingleComponentDetails): string 

    Example:  import { PageAndSingleComponentDetails } from "@conversiondigital/headless-basics-data/src/interfaces";

    export function getQuery(pageAndComponentCombo: PageAndSingleComponentDetails): string { return /* GraphQL */ ` query AllPage($slug: String!) { allPage(where: { slug_current: { eq: $slug } }) { title ... components { ...componentFields } } }

    fragment componentFields on XComponent {
      selectableVariant
      sortOrder
      // additional fields...
    }
    `; } 

STEP 12: Edit File: {COMPONENT}/sanity-mapping.ts
    Example:
        ``` ts
        import { getLogger, logPrefix, PageAndSingleComponentDetails } from "@conversiondigital/headless-basics-data/src"
        import { extractComponentsFromSanityData } from "@conversiondigital/headless-basics-data/src/cms/sanity/sanityMappingUtils"

        export const log = getLogger("default.components.sanity.{COMPONENT}.mapping")

        export async function mapIdentifierData(pageAndComponentCombo: PageAndSingleComponentDetails) {
          log.trace(
            `${logPrefix()}[${pageAndComponentCombo.component.identifier}][${pageAndComponentCombo.page.source}][${pageAndComponentCombo.page.preliminarySlug}] mapIdentifierData started, ${JSON.stringify(pageAndComponentCombo?.component?.data)}`
          );

          const content = pageAndComponentCombo?.component?.data
          const matchingData = extractComponentsFromSanityData(content, "{COMPONENT}", log)

          if (!(matchingData?.image && matchingData.backgroundImage)) {
            matchingData.image = matchingData.backgroundImage;
          }

          return matchingData
        }




