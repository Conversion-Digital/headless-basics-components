}
declare module "next" {
  interface Window {
    isCaptchaLoaded: Record<string, boolean>
    grecaptcha: {
      render: (
        element: HTMLElement,
        options: {
          sitekey: string
          callback?: (token: string) => void
        }
      ) => number
