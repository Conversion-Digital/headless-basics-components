      const DemoVariant: React.FC<StandardComponentProps> = ({ blueprint, componentInformation, matchingData }) => { return ( <section> <h2>{matchingData?.title || demoVariantData.title}</h2> <p>{matchingData?.subtitle || demoVariantData.subtitle}</p> </section> ); };

      export default DemoVariant;

STEP 9: Edit File: index.ts

