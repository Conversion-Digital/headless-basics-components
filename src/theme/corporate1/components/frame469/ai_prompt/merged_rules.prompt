        Create Page parent field should always be:::   parent: {         _type: 'reference',  _ref: '5bbfcbb4-84f3-4301-bc56-8345160d0cb9',  }

STEP 6: Edit File: {COMPONENT}/components/index.tsx

    Description: Uses the variant field to render all variants.

    Example:
        ``` tsx
        import React from "react";
        import { componentBoilerPlate } from "@conversiondigital/headless-basics-data/src/component-tools/componentBoilerPlate";
        import type { ViewComponentProps } from "@conversiondigital/headless-basics-data/src/interfaces/ThemeConfig.interface";
        import DemoVariant from "./variants/demoVariant";
        import { getLogger, logPrefix } from "@conversiondigital/headless-basics-data/src";
        import {COMPONENT}DefaultVariant from "./variants/{COMPONENT}DefaultVariant";

        export const log = getLogger("default.components.heartcore.template.variants");

        export default function {COMPONENT}UI(dynamicComponent: ViewComponentProps) {
          const { variant, matchingData } = componentBoilerPlate(dynamicComponent);
          if (!matchingData) return null;
          log.trace(`${logPrefix} {COMPONENT}UI started, matchingData: ${JSON.stringify(matchingData)}`);
          switch (variant) {
            case "xDemo":
              return <DemoVariant matchingData={matchingData} {...dynamicComponent} />;
            default:
              return <{COMPONENT}DefaultVariant matchingData={matchingData} {...dynamicComponent} />;
          }
        }

STEP 7: Edit File: {COMPONENT}/components/variants/demoVariant.tsx

    Description: Renders an example variant using data from demoVariantData.ts.

    Example:  
      ``` tsx
