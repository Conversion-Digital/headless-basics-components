{
    "output": {
        "filePath": "repomix-output.xml",
        "style": "xml",
        "headerText": "Custom header information for the packed file.",
        "removeComments": true,
        "removeEmptyLines": true,
        "showLineNumbers": false,
        "copyToClipboard": false,
        "topFilesLength": 5,
        "includeEmptyDirectories": false,
        "instructionFilePath": "repomix-base.prompt"
    },
    "include": [
        "**/*"
    ],
    "ignore": {
        "useGitignore": true,
        "useDefaultPatterns": true,
        "customPatterns": [
           ".github",
           ".vscode",
           ".gitignore",
           "*.yml",
           "repomix-base.prompt",
           "repomix-output.xml",
           ".storybook",
           ".idea",
           "public",
           "node_modules",
           "dist",
           "repomix.config.json",
           "package-lock.json",
           ".prettierrc.json",
           "babel.config.cjs",
           "jest.config.cjs",
           "tsconfig.tsbuildinfo",
           "src/mockup-data",
           "src/**/*.stories.tsx",
           "src/theme/default/components/form/components/Form.tsx",
           "src/theme/default/structures/services/search/",
           "src/theme/default/components/sitesearch",
           "src/theme/default/components/services/search/searchRenderService.tsx",
           "src/theme/default/structures/navigation/footer/footer.tsx",
           "src/components/menubar.tsx",
           "src/theme/default/structures/StickyNavigation.tsx",
           "src/theme/default/structures/subscription/subscriptionForm.tsx",
           "src/theme/default/components/common/ecommerce/ProductAccordion.tsx",
           "src/theme/default/structures/MobileMegaMenu.tsx",
           "src/theme/default/styles",
           "src/mock-data",
           "src/styles",
           "src/icons",
           "src/components",
           "src/utils"

        ]
    },
    "security": {
        "enableSecurityCheck": true
    }
}